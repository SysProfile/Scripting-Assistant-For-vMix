{
  "name": "scripting-assistant-for-vmix",
  "displayName": "Scripting Assistant for vMix",
  "description": "%extension.description%",
  "publisher": "sysprofile",
  "icon": "icon.png",
  "version": "0.6.55",
    "repository": {
    "type": "git",
    "url": "https://github.com/SysProfile/Scripting-Assistant-For-vMix.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "configurationDefaults": {
      "[vmix]": {
        "github.copilot.enable": false,
        "editor.wordBasedSuggestions": "off",
        "editor.quickSuggestions": {
          "comments": false,
          "strings": false,
          "other": true
        }
      }
    },
    "configuration": {
      "title": "vMix Scripting",
      "properties": {
        "vmixScripting.projectPath": {
          "type": "string",
          "default": "",
          "description": "%config.projectPath%"
        }
      }
    },
    "commands": [
      {
        "command": "vmixScripting.showMenu",
        "title": "%cmd.showMenu%"
      },
      {
        "command": "vmixScripting.openProject",
        "title": "%cmd.openProject%"
      },
      {
        "command": "vmixScripting.openSettings",
        "title": "%cmd.openSettings%"
      },
      {
        "command": "vmixScripting.installKeymap",
        "title": "%cmd.installKeymap%"
      },
      {
        "command": "vmixScripting.exportScript",
        "title": "%cmd.exportScript%"
      },
      {
        "command": "vmixScripting.importScript",
        "title": "%cmd.importScript%"
      }
    ],
    "languages": [
      {
        "id": "vmix",
        "aliases": [
          "vMix Script",
          "vmix"
        ],
        "extensions": [
          ".vmixscript",
          ".vb"
        ]
      }
    ],
    "grammars": [
      {
        "language": "vmix",
        "scopeName": "source.vmix",
        "path": "./syntaxes/vmix.tmLanguage.json"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:vmix"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "18.18.0",
    "@types/vscode": "^1.80.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.4.5",
    "@vscode/test-electron": "^2.3.2"
  }
}